# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=social-media-stream
KAFKA_OUTPUT_TOPIC=detection-results
KAFKA_CONSUMER_GROUP=misinformation-detectors-group-1

# LLM (Phase 2)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# PostgreSQL (Phase 3)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=echochamber
POSTGRES_USER=echochamber
POSTGRES_PASSWORD=changeme

# S3 / MinIO (Phase 3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=echochamber-raw
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MLflow (Phase 4)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=misinformation-detector

# MLflow server backend/artifact store (Phase 5 — read by k8s/mlflow.yaml via Secret)
MLFLOW_BACKEND_STORE_URI=postgresql://echochamber:changeme@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=s3://echochamber-mlflow/
